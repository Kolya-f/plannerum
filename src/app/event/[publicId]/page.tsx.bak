'use client'

import { useEffect, useState } from 'react'
import { useParams, useRouter } from 'next/navigation'
import Link from 'next/link'
import { useSession } from 'next-auth/react'

interface DateOption {
  id: string
  date: string
  votes: Array<{
    id: string
    type: string
    user: {
      id: string
      name: string | null
    }
  }>
  _count: {
    votes: number
  }
}

interface Event {
  id: string
  title: string
  description: string | null
  isPublic: boolean
  createdAt: string
  creator: {
    id: string
    name: string | null
    email: string
  }
  dateOptions: DateOption[]
}

export default function EventPage() {
  const params = useParams()
  const router = useRouter()
  const { data: session, status } = useSession()
  const publicId = params.publicId as string
  
  const [event, setEvent] = useState<Event | null>(null)
  const [loading, setLoading] = useState(true)
  const [error, setError] = useState<string | null>(null)
  const [voting, setVoting] = useState<string | null>(null)

  useEffect(() => {
    fetchEvent()
  }, [publicId])

  async function fetchEvent() {
    try {
      setLoading(true)
      setError(null)
      
      console.log('🔵 Fetching event:', publicId)
      const response = await fetch(`/api/events/${publicId}`)
      
      if (!response.ok) {
        const errorData = await response.json().catch(() => ({}))
        throw new Error(errorData.error || `Failed to load event: ${response.status}`)
      }

      const data = await response.json()
      console.log('✅ Event loaded:', data.title)
      setEvent(data)
    } catch (err: any) {
      console.error('❌ Error loading event:', err)
      setError(err.message || 'Failed to load event')
    } finally {
      setLoading(false)
    }
  }

  const handleVote = async (dateOptionId: string, voteType: string) => {
    // Перевірка авторизації
    if (status === 'unauthenticated') {
      alert('Будь ласка, увійдіть в систему для голосування')
      router.push('/auth/signin')
      return
    }

    if (status === 'loading') {
      alert('Будь ласка, зачекайте...')
      return
    }

    setVoting(dateOptionId)
    try {
      const response = await fetch(`/api/events/event/${event?.id}/vote`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          dateOptionId,
          voteType
        })
      })

      const data = await response.json()

      if (response.ok) {
        // Оновити подію
        await fetchEvent()
        alert('✅ Голос успішно враховано!')
      } else {
        alert(`❌ Помилка: ${data.error}`)
      }
    } catch (error) {
      console.error('Помилка голосування:', error)
      alert('❌ Помилка при голосуванні')
    } finally {
      setVoting(null)
    }
  }

  // Функція для отримання голосу поточного користувача за конкретну дату
  const getUserVote = (dateOption: DateOption) => {
    if (!session?.user) return null
    const userVote = dateOption.votes.find(vote => vote.user.id === session.user.id)
    return userVote ? userVote.type : null
  }

  // Функція для підрахунку голосів за типами
  const countVotesByType = (dateOption: DateOption) => {
    const counts = { yes: 0, maybe: 0, no: 0 }
    dateOption.votes.forEach(vote => {
      counts[vote.type as keyof typeof counts]++
    })
    return counts
  }

  if (loading) {
    return (
      <div className="min-h-screen flex items-center justify-center">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-500 mx-auto"></div>
          <p className="mt-4 text-gray-600">Loading event...</p>
        </div>
      </div>
    )
  }

  if (error || !event) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center p-4">
        <div className="bg-white rounded-lg shadow p-8 max-w-md w-full">
          <div className="text-center">
            <svg className="mx-auto h-12 w-12 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.998-.833-2.73 0L4.346 16.5c-.77.833.192 2.5 1.732 2.5z" />
            </svg>
            <h3 className="mt-4 text-lg font-medium text-gray-900">Event not found</h3>
            <p className="mt-2 text-gray-600">{error || 'The event could not be loaded.'}</p>
            <div className="mt-6">
              <Link
                href="/dashboard"
                className="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700"
              >
                Back to Dashboard
              </Link>
            </div>
          </div>
        </div>
      </div>
    )
  }

  // Підрахунок голосів
  const totalVotes = event.dateOptions.reduce((sum, option) => sum + option._count.votes, 0)

  return (
    <div className="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
      <div className="max-w-4xl mx-auto">
        <div className="mb-8">
          <Link
            href="/dashboard"
            className="inline-flex items-center text-blue-600 hover:text-blue-800 mb-4"
          >
            ← Back to Dashboard
          </Link>
          <h1 className="text-3xl font-bold text-gray-900">{event.title}</h1>
          {event.description && (
            <p className="mt-2 text-gray-600">{event.description}</p>
          )}
          <div className="mt-4 flex flex-col sm:flex-row sm:items-center text-sm text-gray-500 gap-2">
            <span>Створено {event.creator.name || event.creator.email}</span>
            <span className="hidden sm:inline">•</span>
            <span>{new Date(event.createdAt).toLocaleDateString('uk-UA')}</span>
            <span className="hidden sm:inline">•</span>
            <span>{event.isPublic ? 'Публічна подія' : 'Приватна подія'}</span>
          </div>

          {/* Статус авторизації */}
          <div className="mt-4 p-3 bg-blue-50 rounded-lg">
            {status === 'authenticated' ? (
              <p className="text-blue-700">
                👤 Ви ввійшли як <strong>{session.user.email}</strong>. Ви можете голосувати!
              </p>
            ) : status === 'loading' ? (
              <p className="text-blue-700">Завантаження...</p>
            ) : (
              <p className="text-red-600">
                ⚠️ Ви не авторизовані. 
                <Link href="/auth/signin" className="ml-2 text-blue-600 hover:underline">
                  Увійдіть для голосування
                </Link>
              </p>
            )}
          </div>
        </div>

        <div className="bg-white rounded-lg shadow overflow-hidden">
          <div className="px-6 py-5 border-b border-gray-200">
            <h2 className="text-lg font-medium text-gray-900">
              Варіанти дат ({event.dateOptions.length})
            </h2>
            <p className="mt-1 text-sm text-gray-500">
              Всього голосів: {totalVotes}
            </p>
          </div>
          
          <div className="px-6 py-5">
            <div className="space-y-6">
              {event.dateOptions.map((option) => {
                const voteCount = option._count.votes
                const percentage = totalVotes > 0 ? Math.round((voteCount / totalVotes) * 100) : 0
                const userVote = getUserVote(option)
                const voteCounts = countVotesByType(option)
                const totalOptionVotes = option.votes.length
                
                return (
                  <div key={option.id} className="border border-gray-200 rounded-lg p-6 hover:border-blue-300 transition-colors">
                    <div className="flex flex-col lg:flex-row lg:items-start justify-between gap-4 mb-4">
                      <div className="flex-1">
                        <h3 className="font-medium text-gray-900 text-lg">
                          {new Date(option.date).toLocaleDateString('uk-UA', {
                            weekday: 'long',
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit'
                          })}
                        </h3>
                      </div>
                      
                      {/* Кнопки голосування */}
                      <div className="flex flex-col sm:flex-row gap-2">
                        <button
                          onClick={() => handleVote(option.id, 'yes')}
                          disabled={voting === option.id || status !== 'authenticated'}
                          className={`px-4 py-2 rounded-lg font-medium transition-all ${
                            userVote === 'yes' 
                              ? 'bg-green-600 text-white shadow-md' 
                              : 'bg-green-100 text-green-800 hover:bg-green-200'
                          } ${status !== 'authenticated' ? 'opacity-50 cursor-not-allowed' : ''}`}
                        >
                          {voting === option.id ? '...' : '👍 Так'} ({voteCounts.yes})
                        </button>
                        
                        <button
                          onClick={() => handleVote(option.id, 'maybe')}
                          disabled={voting === option.id || status !== 'authenticated'}
                          className={`px-4 py-2 rounded-lg font-medium transition-all ${
                            userVote === 'maybe' 
                              ? 'bg-yellow-600 text-white shadow-md' 
                              : 'bg-yellow-100 text-yellow-800 hover:bg-yellow-200'
                          } ${status !== 'authenticated' ? 'opacity-50 cursor-not-allowed' : ''}`}
                        >
                          {voting === option.id ? '...' : '🤔 Можливо'} ({voteCounts.maybe})
                        </button>
                        
                        <button
                          onClick={() => handleVote(option.id, 'no')}
                          disabled={voting === option.id || status !== 'authenticated'}
                          className={`px-4 py-2 rounded-lg font-medium transition-all ${
                            userVote === 'no' 
                              ? 'bg-red-600 text-white shadow-md' 
                              : 'bg-red-100 text-red-800 hover:bg-red-200'
                          } ${status !== 'authenticated' ? 'opacity-50 cursor-not-allowed' : ''}`}
                        >
                          {voting === option.id ? '...' : '👎 Ні'} ({voteCounts.no})
                        </button>
                      </div>
                    </div>
                    
                    {/* Прогрес-бари для результатів */}
                    {totalOptionVotes > 0 && (
                      <div className="mt-4 space-y-2">
                        <div className="flex items-center">
                          <span className="w-20 text-sm text-green-700">Так:</span>
                          <div className="flex-1 bg-gray-200 rounded-full h-2.5">
                            <div 
                              className="bg-green-500 h-2.5 rounded-full transition-all duration-500"
                              style={{ 
                                width: totalOptionVotes > 0 ? `${(voteCounts.yes / totalOptionVotes) * 100}%` : '0%'
                              }}
                            ></div>
                          </div>
                          <span className="ml-2 text-sm font-medium">{voteCounts.yes}</span>
                        </div>

                        <div className="flex items-center">
                          <span className="w-20 text-sm text-yellow-700">Можливо:</span>
                          <div className="flex-1 bg-gray-200 rounded-full h-2.5">
                            <div 
                              className="bg-yellow-500 h-2.5 rounded-full transition-all duration-500"
                              style={{ 
                                width: totalOptionVotes > 0 ? `${(voteCounts.maybe / totalOptionVotes) * 100}%` : '0%'
                              }}
                            ></div>
                          </div>
                          <span className="ml-2 text-sm font-medium">{voteCounts.maybe}</span>
                        </div>

                        <div className="flex items-center">
                          <span className="w-20 text-sm text-red-700">Ні:</span>
                          <div className="flex-1 bg-gray-200 rounded-full h-2.5">
                            <div 
                              className="bg-red-500 h-2.5 rounded-full transition-all duration-500"
                              style={{ 
                                width: totalOptionVotes > 0 ? `${(voteCounts.no / totalOptionVotes) * 100}%` : '0%'
                              }}
                            ></div>
                          </div>
                          <span className="ml-2 text-sm font-medium">{voteCounts.no}</span>
                        </div>
                      </div>
                    )}
                    
                    {/* Загальна статистика */}
                    <div className="mt-4 pt-4 border-t border-gray-100">
                      <div className="flex justify-between items-center">
                        <div className="text-sm text-gray-600">
                          <span className="font-medium">Всього голосів: {voteCount}</span>
                          {userVote && (
                            <span className="ml-3 text-blue-600">
                              • Ваш голос: <strong>
                                {userVote === 'yes' ? 'Так' : 
                                 userVote === 'maybe' ? 'Можливо' : 'Ні'}
                              </strong>
                            </span>
                          )}
                        </div>
                        {totalVotes > 0 && (
                          <div className="text-sm font-semibold text-blue-600">
                            {percentage}% від загальної кількості
                          </div>
                        )}
                      </div>
                    </div>
                    
                    {/* Список голосів */}
                    {option.votes.length > 0 && (
                      <div className="mt-3 pt-3 border-t border-gray-100">
                        <div className="text-sm font-medium text-gray-700 mb-2">Хто проголосував:</div>
                        <div className="flex flex-wrap gap-2">
                          {option.votes.map((vote) => (
                            <div
                              key={vote.id}
                              className={`px-3 py-1.5 rounded-full text-sm flex items-center gap-1 ${
                                vote.type === 'yes'
                                  ? 'bg-green-100 text-green-800 border border-green-200'
                                  : vote.type === 'maybe'
                                  ? 'bg-yellow-100 text-yellow-800 border border-yellow-200'
                                  : 'bg-gray-100 text-gray-800 border border-gray-200'
                              }`}
                            >
                              <span>{vote.user.name || 'Гість'}</span>
                              <span className={`px-1.5 py-0.5 rounded text-xs ${
                                vote.type === 'yes' ? 'bg-green-200' :
                                vote.type === 'maybe' ? 'bg-yellow-200' : 'bg-gray-200'
                              }`}>
                                {vote.type === 'yes' ? '👍' :
                                 vote.type === 'maybe' ? '🤔' : '👎'}
                              </span>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                )
              })}
            </div>
            
            {event.dateOptions.length === 0 && (
              <div className="text-center py-8">
                <svg className="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <h3 className="mt-4 text-lg font-medium text-gray-900">Немає варіантів дат</h3>
                <p className="mt-2 text-gray-500">Додайте дати для голосування.</p>
              </div>
            )}
          </div>
          
          <div className="px-6 py-4 bg-gray-50 border-t border-gray-200">
            <div className="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4">
              <div className="text-sm text-gray-500">
                <p className="font-medium mb-1">Поділіться посиланням:</p>
                <code className="px-3 py-2 bg-gray-100 rounded text-gray-800 block break-all">
                  {typeof window !== 'undefined' ? `${window.location.origin}/event/${event.id}` : ''}
                </code>
              </div>
              <div className="flex flex-col sm:flex-row gap-3">
                <button
                  onClick={() => {
                    if (typeof window !== 'undefined') {
                      navigator.clipboard.writeText(`${window.location.origin}/event/${event.id}`)
                      alert('Посилання скопійовано!')
                    }
                  }}
                  className="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg font-medium hover:bg-gray-50 flex items-center justify-center gap-2"
                >
                  <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                  </svg>
                  Копіювати посилання
                </button>
                <button
                  onClick={() => fetchEvent()}
                  className="px-4 py-2 bg-blue-100 text-blue-700 rounded-lg font-medium hover:bg-blue-200 flex items-center justify-center gap-2"
                >
                  <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                  </svg>
                  Оновити результати
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  )
}
