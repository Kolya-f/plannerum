generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("emailVerified")
  image         String?
  createdAt     DateTime  @default(now()) @map("createdAt")
  updatedAt     DateTime  @updatedAt @map("updatedAt")
  
  events        Event[]
  votes         Vote[]
  chatMessages  ChatMessage[]
  onlineUsers   OnlineUser[]

  @@map("users")
}

model Event {
  id              String    @id @default(cuid())
  title           String
  description     String?
  location        String?
  category        String?   @default("other")
  maxParticipants Int?      @map("maxParticipants")
  isPublic        Boolean   @default(true) @map("isPublic")
  userId          String    @map("userId")
  userName        String?   @map("userName")
  userEmail       String?   @map("userEmail")
  createdAt       DateTime  @default(now()) @map("createdAt")
  updatedAt       DateTime  @updatedAt @map("updatedAt")
  
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateOptions DateOption[]
  votes       Vote[]
  chatMessages ChatMessage[]

  @@map("events")
}

model DateOption {
  id      String   @id @default(cuid())
  date    DateTime
  eventId String   @map("eventId")
  
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  votes Vote[]

  @@map("date_options")
}

model Vote {
  id           String   @id @default(cuid())
  voteType     String   @default("yes") @map("voteType")
  userId       String   @map("userId")
  userName     String?  @map("userName")
  userEmail    String?  @map("userEmail")
  eventId      String   @map("eventId")
  dateOptionId String   @map("dateOptionId")
  createdAt    DateTime @default(now()) @map("createdAt")
  
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dateOption DateOption @relation(fields: [dateOptionId], references: [id], onDelete: Cascade)
  
  @@unique([userId, eventId])
  @@map("votes")
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  userId    String   @map("userId")
  userName  String?  @map("userName")
  userEmail String?  @map("userEmail")
  eventId   String?  @map("eventId")
  createdAt DateTime @default(now()) @map("createdAt")
  
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model OnlineUser {
  id        String   @id @default(cuid())
  userId    String   @unique @map("userId")
  userName  String?  @map("userName")
  userEmail String?  @map("userEmail")
  lastSeen  DateTime @default(now()) @map("lastSeen")
  createdAt DateTime @default(now()) @map("createdAt")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("online_users")
}
